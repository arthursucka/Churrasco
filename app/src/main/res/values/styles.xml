<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Churrasco.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/md_on_primary</item>
        <item name="backgroundTint">@color/md_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="iconSize">20dp</item>
    </style>

    <style name="Churrasco.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/md_secondary</item>
        <item name="backgroundTint">@color/md_surface</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/md_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Churrasco.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/md_secondary</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Churrasco.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/md_surface</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeColor">@color/md_outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Churrasco.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_primary</item>
        <item name="hintTextColor">@color/md_primary</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>
</resources>
